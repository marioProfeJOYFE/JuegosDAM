<Window x:Class="JuegosDAM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Biblioteca de Juegos" Height="700" Width="1000"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Border CornerRadius="30" MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FCECD8" Offset="0.0"/>
                <GradientStop Color="#C1C7D0" Offset="0.4"/>
                <GradientStop Color="#1A436A" Offset="1.0"/>
            </LinearGradientBrush>
        </Border.Background>
        
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="CornerRadius" Value="30"/>
                
                <Style.Triggers>
                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                        <Setter Property="CornerRadius" Value="0"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource GlassPanelStyle}" Margin="0,0,15,0">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource GlassPanelStyle}" CornerRadius="20" Padding="10" Margin="0,0,0,30">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="50" Height="50" Margin="0,0,15,0">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="https://upload.wikimedia.org/wikipedia/commons/d/d7/Cristiano_Ronaldo_playing_for_Al_Nassr_FC_against_Persepolis%2C_September_2023_%28cropped%29.jpg"
                                                Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Mario Ríos" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Cuenta Premium" FontSize="11" Foreground="#9C527B"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,30">
                        <Border Style="{StaticResource NavButtonStyle}" Background="#B2D07C">
                            <TextBlock Text="🎮" FontSize="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Style="{StaticResource NavButtonStyle}" Background="#D088C3">
                            <TextBlock Text="🔍" FontSize="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Style="{StaticResource NavButtonStyle}" Background="#85CDD3" Margin="0">
                            <TextBlock Text="👥" FontSize="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Text="Recientes" Style="{StaticResource SubtitleTextStyle}" FontWeight="Bold" Margin="0,0,0,15"/>

                    <StackPanel Grid.Row="3">
                        <Border Style="{StaticResource GlassPanelStyle}" CornerRadius="20" Padding="15" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="60" Background="#333" CornerRadius="5" Margin="0,0,10,0"/> <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Tomb Raider" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="Hace 13 minutos" FontSize="11" Foreground="#DDD"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="▶" Foreground="White" FontSize="20" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource GlassPanelStyle}" CornerRadius="20" Padding="15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="60" Background="#333" CornerRadius="5" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Tomb Raider" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="Hace 13 minutos" FontSize="11" Foreground="#DDD"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="▶" Foreground="White" FontSize="20" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <Border Grid.Row="4" Style="{StaticResource NavButtonStyle}" Background="#7982B8" HorizontalAlignment="Left" Margin="0">
                        <TextBlock Text="⚙" FontSize="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource GlassPanelStyle}">
                <Grid Margin="40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-20,-20,0">
                        <Ellipse Width="15" Height="15" Fill="#FF605C" Margin="0,0,8,0" 
                                 Cursor="Hand" ToolTip="Cerrar" MouseLeftButtonDown="BtnClose_Click"/>
    
                        <Ellipse Width="15" Height="15" Fill="#FFBD44" Margin="0,0,8,0" 
                                 Cursor="Hand" ToolTip="Minimizar" MouseLeftButtonDown="BtnMinimize_Click"/>
    
                        <Ellipse Width="15" Height="15" Fill="#00CA4E" 
                                 Cursor="Hand" ToolTip="Maximizar" MouseLeftButtonDown="BtnMaximize_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Margin="0,0,0,40">
                        <TextBlock Text="Biblioteca de Juegos" Style="{StaticResource TitleTextStyle}"/>
                        <TextBlock Text="Aquí encontrarás todos tus títulos" Style="{StaticResource SubtitleTextStyle}" Margin="0,5,0,0"/>
                    </StackPanel>

                    <UniformGrid Grid.Row="1" Columns="4" VerticalAlignment="Top">
                        <StackPanel Style="{StaticResource GamePlaceholderStyle}">
                            <Border Style="{StaticResource GameCoverPlaceholderStyle}" Background="#C49B61"/>
                            <Border Height="8" Background="#DDD" CornerRadius="4" Margin="0,0,0,5"/>
                            <Border Height="8" Background="#DDD" CornerRadius="4" Width="80" HorizontalAlignment="Left"/>
                        </StackPanel>
                        
                        <StackPanel Style="{StaticResource GamePlaceholderStyle}">
                            <Border Style="{StaticResource GameCoverPlaceholderStyle}" Background="#6B82B8"/>
                            <Border Height="8" Background="#DDD" CornerRadius="4" Margin="0,0,0,5"/>
                            <Border Height="8" Background="#DDD" CornerRadius="4" Width="80" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <StackPanel Style="{StaticResource GamePlaceholderStyle}">
                            <Border Style="{StaticResource GameCoverPlaceholderStyle}" Background="#BB6C78"/>
                            <Border Height="8" Background="#DDD" CornerRadius="4" Margin="0,0,0,5"/>
                            <Border Height="8" Background="#DDD" CornerRadius="4" Width="80" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <StackPanel Style="{StaticResource GamePlaceholderStyle}">
                            <Border Style="{StaticResource GameCoverPlaceholderStyle}" Background="#A9B862"/>
                            <Border Height="8" Background="#DDD" CornerRadius="4" Margin="0,0,0,5"/>
                            <Border Height="8" Background="#DDD" CornerRadius="4" Width="80" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <StackPanel Style="{StaticResource GamePlaceholderStyle}">
                            <Border Style="{StaticResource GameCoverPlaceholderStyle}" Background="#B86E66"/>
                            <Border Height="8" Background="#DDD" CornerRadius="4" Margin="0,0,0,5"/>
                            <Border Height="8" Background="#DDD" CornerRadius="4" Width="80" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <StackPanel Style="{StaticResource GamePlaceholderStyle}">
                            <Border Style="{StaticResource GameCoverPlaceholderStyle}" Background="#69B58D"/>
                            <Border Height="8" Background="#DDD" CornerRadius="4" Margin="0,0,0,5"/>
                            <Border Height="8" Background="#DDD" CornerRadius="4" Width="80" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <StackPanel Style="{StaticResource GamePlaceholderStyle}">
                            <Border Style="{StaticResource GameCoverPlaceholderStyle}" Background="#836BB8"/>
                            <Border Height="8" Background="#DDD" CornerRadius="4" Margin="0,0,0,5"/>
                            <Border Height="8" Background="#DDD" CornerRadius="4" Width="80" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <StackPanel Style="{StaticResource GamePlaceholderStyle}">
                            <Border Style="{StaticResource GameCoverPlaceholderStyle}" Background="#B3A599"/>
                            <Border Height="8" Background="#DDD" CornerRadius="4" Margin="0,0,0,5"/>
                            <Border Height="8" Background="#DDD" CornerRadius="4" Width="80" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>