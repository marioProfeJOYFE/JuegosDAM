<Window x:Class="JuegosDAM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:JuegosDAM"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Border CornerRadius="30">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FCECD8" Offset="0.0"/>
                <GradientStop Color="#C1C7D0" Offset="0.4"/>
                <GradientStop Color="#1A436A" Offset="1.0"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{ StaticResource GlassPanelStyle}"
                    Margin="10"
                    Grid.Column="0">
                <StackPanel Orientation="Vertical" Margin="10">
                    <Border 
                        Height="80"
                        Style="{ StaticResource GlassPanelStyle}"
                        >
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Image Width="50"
                                   Height="50"
                                />
                            <StackPanel 
                                Orientation="Vertical"
                                VerticalAlignment="Center"
                                >
                                <TextBlock Text="Mario Ríos" />
                                <TextBlock 
                                    Text="Cuenta Premium" 
                                    FontSize="8"
                                           />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel 
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,10,0,0"
                        >
                        <Border 
                            Background="GreenYellow" 
                            CornerRadius="10"
                            Margin="0,0,10,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            >
                            <TextBlock Text="🎮" FontSize="30" TextAlignment="Center"/>
                        </Border>
                        <Border 
                            Background="MediumPurple" 
                            Margin="0,0,10,0"
                            CornerRadius="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            >
                            <TextBlock Text="🔎" FontSize="30" TextAlignment="Center"/>
                        </Border>
                        <Border 
                            Background="DeepSkyBlue" 
                            CornerRadius="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            >
                            <TextBlock Text="🧑" FontSize="30" TextAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <TextBlock Text="Recientes" Margin="0,20,0,0"/>
                    <Border Background="CadetBlue"
                            Height="60"
                            CornerRadius="10"
                            >
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Image Width="50"
                                   Height="50"
                                />
                            <StackPanel 
                                Orientation="Vertical"
                                VerticalAlignment="Center"
                                >
                                <TextBlock Text="Mario Ríos" />
                                <TextBlock 
                    Text="Cuenta Premium" 
                    FontSize="8"
                           />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Background="CadetBlue"
            Height="60"
            CornerRadius="10"
            >
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Image Width="50"
                   Height="50"
                />
                            <StackPanel 
                Orientation="Vertical"
                VerticalAlignment="Center"
                >
                                <TextBlock Text="Mario Ríos" />
                                <TextBlock 
    Text="Cuenta Premium" 
    FontSize="8"
           />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

            <Border Style="{ StaticResource GlassPanelStyle}"
                    Margin="10"
                    Grid.Column="1">
                <StackPanel 
                    Orientation="Vertical"
                    Margin="10"
                    >
                    <TextBlock 
                        Text="Biblioteca de Juegos"
                        Style="{StaticResource TitleTextStyle}"/>

                    <TextBlock
                        Margin="0,10,0,0"
                        Text="Aquí encontrarás todos tus títulos"
                        FontSize="16"
                        FontWeight="Medium"/>

                    <Image
                        Width="70"
                        Height="70"
                        Stretch="UniformToFill"
                        />

                    <ItemsControl>

                    </ItemsControl>

                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
